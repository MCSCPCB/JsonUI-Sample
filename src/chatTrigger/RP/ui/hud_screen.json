{
  "namespace": "hud",

  "chat_trigger_alpha_out": {
    "anim_type": "alpha",
    "easing": "in_quart",
    "duration": 0.25,
    "from": 1,
    "to": 0,
    "destroy_at_end": "chat_grid_item"
  },

  "chat_trigger_wait": {
    "anim_type": "wait",
    "duration": 2,
    "next": "@hud.chat_trigger_alpha_out"
  },

  "chat_trigger_alpha_in": {
    "anim_type": "alpha",
    "easing": "out_cubic",
    "duration": 0.25,
    "from": 0,
    "to": 1,
    "next": "@hud.chat_trigger_wait"
  },

  "chat_trigger_generator": {
    "type": "panel",
    "size": ["100%", "100%"],
    "layer": 100,
    "controls": [
      {
        "chat_trigger_factory": {
          "type": "collection_panel",
          "size": ["100%", "100%"],
          "factory": {
            "name": "chat_trigger_generator_factory",
            "control_name": "hud.chat_trigger_display"
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(#text - '<' - '>')",
              "target_property_name": "#text_n"
            },
            {
              "binding_type": "view",
              "source_property_name": "(not (#text_n - $flag_for_chat_trigger_show = #text_n) * 1)",
              "target_property_name": "#collection_length"
            }
          ]
        }
      }
    ]
  },

  "chat_trigger_display": {
    "type": "panel",
    "size": ["100%", "100%"],
    "layer": 100,
    "controls": [
      {
        "chat_trigger_image": {
          "type": "image",
          "texture": "textures/ui/chat_trigger_placeholder",
          "size": [128, 128],
          "anchor_from": "center",
          "anchor_to": "center",
          "keep_ratio": true,
          "anims": [
            "@hud.chat_trigger_alpha_in"
          ]
        }
      }
    ]
  },

  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "chat_trigger_listener": {
              "type": "panel",
              "factory": {
                "name": "chat_item_factory",
                "control_ids": {
                  "chat_item": "chat_trigger_generator@hud.chat_trigger_generator"
                }
              }
            }
          }
        ]
      }
    ]
  }
}
